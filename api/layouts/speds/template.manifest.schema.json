{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://central-utils.local/schemas/sped-template-manifest.schema.json",
  "title": "SPED Template Manifest",
  "description": "Contrato padrao para novos templates SPED orientados a configuracao.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "templateId",
    "spedType",
    "operation",
    "inputs",
    "targets",
    "cascadePolicy",
    "validators",
    "totalizers",
    "output",
    "dryRun"
  ],
  "properties": {
    "templateId": {
      "type": "string",
      "minLength": 3
    },
    "spedType": {
      "type": "string",
      "enum": ["icms", "contribuicoes", "ecd", "ecf"]
    },
    "operation": {
      "type": "string",
      "enum": ["insert", "update", "delete", "mixed", "analyze"]
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label", "required", "multiple", "acceptedExtensions"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "multiple": { "type": "boolean" },
          "acceptedExtensions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^\\.[a-z0-9]+$"
            }
          },
          "help": { "type": "string" }
        }
      }
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label", "type", "required"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["text", "number", "select", "date", "checkbox"] },
          "required": { "type": "boolean" },
          "defaultValue": {},
          "placeholder": { "type": "string" },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["value", "label"],
              "properties": {
                "value": { "type": "string" },
                "label": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["records"],
      "properties": {
        "records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[0-9A-Z]{4}$"
          }
        },
        "relationshipsFile": { "type": "string" }
      }
    },
    "cascadePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "onMissingDependency", "onOrphanDetected"],
      "properties": {
        "enabled": { "type": "boolean" },
        "onMissingDependency": { "type": "string", "enum": ["abort", "cascade", "skip"] },
        "onOrphanDetected": { "type": "string", "enum": ["abort", "cleanup"] }
      }
    },
    "validators": {
      "type": "object",
      "additionalProperties": false,
      "required": ["globalRelationshipValidation", "duplicateKeyCheck", "hierarchyCheck"],
      "properties": {
        "globalRelationshipValidation": { "type": "boolean" },
        "duplicateKeyCheck": { "type": "boolean" },
        "hierarchyCheck": { "type": "boolean" },
        "rulesFile": { "type": "string" },
        "maxIssues": { "type": "integer", "minimum": 1 }
      }
    },
    "totalizers": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "pattern": "^[0-9A-Z]{4}$"
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formats"],
      "properties": {
        "formats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["txt", "xlsx", "csv", "json"]
          }
        },
        "filenamePattern": { "type": "string" }
      }
    },
    "dryRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "reportChanges", "requireConfirmation"],
      "properties": {
        "enabled": { "type": "boolean" },
        "reportChanges": { "type": "boolean" },
        "requireConfirmation": { "type": "boolean" }
      }
    }
  }
}
